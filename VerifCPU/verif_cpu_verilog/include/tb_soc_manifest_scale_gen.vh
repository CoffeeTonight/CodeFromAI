  task soc_manifest_setup_cpu;
    input [3:0] cid;
    input [8*8:1] name;
    input [31:0] pool_base;
    begin
      case (cid)
        4'd1: begin
          g_slv0.u_bus.u_cpu.cpu_init();
          g_slv0.u_bus.u_cpu.cpu_set_name(name);
          g_slv0.u_bus.u_cpu.cpu_attach_pool_region(pool_base, FW_SIZE);
          g_slv0.u_bus.u_cpu.cpu_attach_recorder();
        end
        4'd2: begin
          g_slv1.u_bus.u_cpu.cpu_init();
          g_slv1.u_bus.u_cpu.cpu_set_name(name);
          g_slv1.u_bus.u_cpu.cpu_attach_pool_region(pool_base, FW_SIZE);
          g_slv1.u_bus.u_cpu.cpu_attach_recorder();
        end
        4'd3: begin
          g_slv2.u_bus.u_cpu.cpu_init();
          g_slv2.u_bus.u_cpu.cpu_set_name(name);
          g_slv2.u_bus.u_cpu.cpu_attach_pool_region(pool_base, FW_SIZE);
          g_slv2.u_bus.u_cpu.cpu_attach_recorder();
        end
        default: ;
      endcase
    end
  endtask

  task soc_manifest_run_phase_a;
    input [3:0] cid;
    begin
      case (cid)
        4'd1: begin
          g_slv0.u_bus.u_cpu.pc = 32'h000;
          g_slv0.u_bus.u_cpu.state = `CPU_STATE_RUNNING;
          g_slv0.u_bus.u_cpu.request_sim_stop = 0;
          g_slv0.u_bus.u_cpu.sim_stop = 0;
        end
        4'd2: begin
          g_slv1.u_bus.u_cpu.pc = 32'h000;
          g_slv1.u_bus.u_cpu.state = `CPU_STATE_RUNNING;
          g_slv1.u_bus.u_cpu.request_sim_stop = 0;
          g_slv1.u_bus.u_cpu.sim_stop = 0;
        end
        4'd3: begin
          g_slv2.u_bus.u_cpu.pc = 32'h000;
          g_slv2.u_bus.u_cpu.state = `CPU_STATE_RUNNING;
          g_slv2.u_bus.u_cpu.request_sim_stop = 0;
          g_slv2.u_bus.u_cpu.sim_stop = 0;
        end
        default: ;
      endcase
    end
  endtask

  task soc_manifest_run_cpu;
    input [3:0]  cid;
    input [31:0] offset;
    input [31:0] max_steps;
    reg [31:0] cyc;
    begin
      case (cid)
        4'd1: begin
          g_slv0.u_bus.u_cpu.pc = offset;
          g_slv0.u_bus.u_cpu.state = `CPU_STATE_RUNNING;
          g_slv0.u_bus.u_cpu.request_sim_stop = 0;
          g_slv0.u_bus.u_cpu.sim_stop = 0;
          for (cyc = 0; cyc < max_steps; cyc = cyc + 1) begin
            @(posedge soc_clk);
            if (g_slv0.u_bus.u_cpu.request_sim_stop || g_slv0.u_bus.u_cpu.sim_stop)
              cyc = max_steps;
          end
        end
        4'd2: begin
          g_slv1.u_bus.u_cpu.pc = offset;
          g_slv1.u_bus.u_cpu.state = `CPU_STATE_RUNNING;
          g_slv1.u_bus.u_cpu.request_sim_stop = 0;
          g_slv1.u_bus.u_cpu.sim_stop = 0;
          for (cyc = 0; cyc < max_steps; cyc = cyc + 1) begin
            @(posedge soc_clk);
            if (g_slv1.u_bus.u_cpu.request_sim_stop || g_slv1.u_bus.u_cpu.sim_stop)
              cyc = max_steps;
          end
        end
        4'd3: begin
          g_slv2.u_bus.u_cpu.pc = offset;
          g_slv2.u_bus.u_cpu.state = `CPU_STATE_RUNNING;
          g_slv2.u_bus.u_cpu.request_sim_stop = 0;
          g_slv2.u_bus.u_cpu.sim_stop = 0;
          for (cyc = 0; cyc < max_steps; cyc = cyc + 1) begin
            @(posedge soc_clk);
            if (g_slv2.u_bus.u_cpu.request_sim_stop || g_slv2.u_bus.u_cpu.sim_stop)
              cyc = max_steps;
          end
        end
        default: ;
      endcase
    end
  endtask

  task soc_manifest_wait_stopped;
    input [31:0] max_cyc;
    reg [31:0] cyc;
    reg        all_done;
    begin
      cyc = 0;
      while (cyc < max_cyc) begin
        all_done = 1;
        if (!g_slv0.u_bus.u_cpu.sim_stop) all_done = 0;
        if (!g_slv1.u_bus.u_cpu.sim_stop) all_done = 0;
        if (!g_slv2.u_bus.u_cpu.sim_stop) all_done = 0;
        if (all_done) cyc = max_cyc;
        else begin
          @(posedge soc_clk);
          cyc = cyc + 1;
        end
      end
    end
  endtask

  task soc_manifest_exec_icode;
    input [3:0]  cid;
    input [31:0] icode_ptr;
    output       ok;
    reg [31:0] txn_before;
    begin
      ok = 0;
      case (cid)
        4'd1: begin
          txn_before = g_slv0.u_bus.u_cpu.bus_txn_count;
          u_pool.pool_use_array(cid);
          u_pool.pool_assign_region(cid, 32'h1e000, ICODE_POOL_SZ);
          g_slv0.u_bus.u_cpu.pc = icode_ptr;
          g_slv0.u_bus.u_cpu.state = `CPU_STATE_RUNNING;
          g_slv0.u_bus.u_cpu.request_sim_stop = 0;
          g_slv0.u_bus.u_cpu.sim_stop = 0;
          soc_manifest_run_cpu(cid, icode_ptr, 48);
          ok = (g_slv0.u_bus.u_cpu.request_sim_stop || g_slv0.u_bus.u_cpu.sim_stop)
               && (g_slv0.u_bus.u_cpu.bus_txn_count > txn_before);
          u_pool.pool_use_array(cid);
          u_pool.pool_assign_region(cid, 32'h0, FW_SIZE);
        end
        4'd2: begin
          txn_before = g_slv1.u_bus.u_cpu.bus_txn_count;
          u_pool.pool_use_array(cid);
          u_pool.pool_assign_region(cid, 32'h1e000, ICODE_POOL_SZ);
          g_slv1.u_bus.u_cpu.pc = icode_ptr;
          g_slv1.u_bus.u_cpu.state = `CPU_STATE_RUNNING;
          g_slv1.u_bus.u_cpu.request_sim_stop = 0;
          g_slv1.u_bus.u_cpu.sim_stop = 0;
          soc_manifest_run_cpu(cid, icode_ptr, 48);
          ok = (g_slv1.u_bus.u_cpu.request_sim_stop || g_slv1.u_bus.u_cpu.sim_stop)
               && (g_slv1.u_bus.u_cpu.bus_txn_count > txn_before);
          u_pool.pool_use_array(cid);
          u_pool.pool_assign_region(cid, 32'h800, FW_SIZE);
        end
        4'd3: begin
          txn_before = g_slv2.u_bus.u_cpu.bus_txn_count;
          u_pool.pool_use_array(cid);
          u_pool.pool_assign_region(cid, 32'h1e000, ICODE_POOL_SZ);
          g_slv2.u_bus.u_cpu.pc = icode_ptr;
          g_slv2.u_bus.u_cpu.state = `CPU_STATE_RUNNING;
          g_slv2.u_bus.u_cpu.request_sim_stop = 0;
          g_slv2.u_bus.u_cpu.sim_stop = 0;
          soc_manifest_run_cpu(cid, icode_ptr, 48);
          ok = (g_slv2.u_bus.u_cpu.request_sim_stop || g_slv2.u_bus.u_cpu.sim_stop)
               && (g_slv2.u_bus.u_cpu.bus_txn_count > txn_before);
          u_pool.pool_use_array(cid);
          u_pool.pool_assign_region(cid, 32'h1000, FW_SIZE);
        end
        default: ;
      endcase
    end
  endtask

