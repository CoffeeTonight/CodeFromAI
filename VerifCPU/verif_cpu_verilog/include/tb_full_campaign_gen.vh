`define CAMPAIGN_PHASE_B_SLOT_CHECK (sl_slot_count[0] >= 2 && sl_slot_count[1] >= 2 && sl_slot_count[2] >= 2)

`define CAMPAIGN_ICODE_RV32_EXEC \
