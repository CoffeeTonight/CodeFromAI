# EDA compile manifest — Work — customer SoC (RTL only, no TB)
# Order: incdirs → defines → vcpu → rtl → tb_top
# VCS:  vcs -sverilog -full64 -F filelists/eda/work/integration/manifest.list -top verif_vcpu_soc_cell
# xrun: xrun -64bit -sv -F filelists/eda/work/integration/manifest.list -top verif_vcpu_soc_cell
# Run from verif_cpu_verilog/ (package root)

-F filelists/eda/work/integration/incdirs.list
-F filelists/eda/work/integration/defines.list
-F filelists/eda/work/integration/vcpu.list
-F filelists/eda/work/integration/rtl.list
