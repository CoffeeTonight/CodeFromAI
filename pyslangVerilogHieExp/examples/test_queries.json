[
  "module ~ \"uart\"",
  "inst ~ \"*uart*\"",
  "module ~ \"uart*5*\"",
  "uart*5*",
  "module in (\"uart*5*\")",
  "module in (\"uart*5*\", \"spi\") AND port ~ \"irq\"",
  "inst in (\"*cpu*\", \"*gpu*\") AND port ~ \"irq\"",
  "module ~ \"uart*0*\" AND port ~ \"irq\"",
  "inst ~ \"*cpu*\" AND port ~ \"irq\""
]
