# EDA compile manifest — Test — scale integration TB
# Order: incdirs → defines → vcpu → rtl → tb_top
# VCS:  vcs -sverilog -full64 -F filelists/eda/test/soc_manifest_scale/manifest.list -top tb_soc_manifest_scale
# xrun: xrun -64bit -sv -F filelists/eda/test/soc_manifest_scale/manifest.list -top tb_soc_manifest_scale
# Run from verif_cpu_verilog/ (package root)

-F filelists/eda/test/soc_manifest_scale/incdirs.list
-F filelists/eda/test/soc_manifest_scale/defines.list
-F filelists/eda/test/soc_manifest_scale/vcpu.list
-F filelists/eda/test/soc_manifest_scale/rtl.list
-F filelists/eda/test/soc_manifest_scale/tb_top.list
