  check_eq("Icode map SFR_CFG", `ICODE_BUS_CHECK_SFR_MASK == 32'h40000004); \
  check_eq("Icode map SRAM_MARKER", `ICODE_BUS_CHECK_SRAM_MARKER == 32'h80000000); \
