{
  "workspace_id": "local-dev",
  "user": {
    "id": "dev",
    "notify_channel": "slack:#soc-verify-dev"
  },
  "confluence": {
    "mode": "dummy",
    "base_url": "https://confluence.example.com",
    "deployment": "cloud",
    "auth": {
      "type": "api_token",
      "user_env": "CONFLUENCE_USER_EMAIL",
      "token_env": "CONFLUENCE_API_TOKEN"
    },
    "hints": {
      "project_discovery": {
        "cql": "space=DV AND label=active-soc",
        "root_page_id": "123456789",
        "project_table_heading": "Active SoC Projects",
        "project_id_column": "Project ID"
      },
      "milestone_section_heading": "Milestones",
      "field_map": {
        "git_url": "Git Repository",
        "doc_rev": "Spec Revision",
        "doc_path": "Verification Spec",
        "jira_epic": "JIRA Epic"
      },
      "verification_group_table_heading": "Verification Groups",
      "notes": "Local dev — dummy intake. Production: copy config.example.json and set confluence.mode=live."
    }
  },
  "git": {
    "clone_root": "/work/repos",
    "tag_pattern": "v*",
    "default_remote": "origin",
    "auth": {
      "ssh_key_env": "GIT_SSH_KEY_PATH"
    }
  },
  "jira": {
    "enabled": false,
    "base_url": "https://jira.example.com",
    "deployment": "cloud",
    "project_key": "SOC",
    "issue_type": "Verification",
    "auth": {
      "type": "api_token",
      "user_env": "JIRA_USER_EMAIL",
      "token_env": "JIRA_API_TOKEN"
    },
    "field_map": {
      "completeness": "customfield_10010",
      "verdict": "customfield_10011",
      "tag": "customfield_10012"
    }
  },
  "llm": {
    "mode": "stub",
    "endpoint": "",
    "model": "soc-dv-agent",
    "md_only": true,
    "auth": {
      "token_env": "COMPANY_LLM_TOKEN"
    }
  },
  "schedules": {
    "project_search_days": 7,
    "project_intake_days": 30,
    "tag_refresh_days": 4,
    "monthly_intake_cron": "0 9 1 * *",
    "timezone": "Asia/Seoul"
  },
  "environment": {
    "profile": "local-eda",
    "module_init": "",
    "license_queue": ""
  },
  "paths": {
    "obsidian_vault": "./vault",
    "projects_root": "./projects"
  },
  "overrides": {}
}