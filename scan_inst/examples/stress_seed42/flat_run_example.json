{
  "filelist": "filelist.f",
  "top": "stress_top",
  "defines": {
    "STRESS_USE_IN": "1",
    "STRESS_ALT": "0"
  },
  "run_on_full_db": {
    "enable": 1,
    "mode": "hierarchy",
    "ignore_path": [],
    "ignore_module": [],
    "ignore_filelist": [],
    "jobs": 0,
    "no_cache": true,
    "output": "example_instances.tsv"
  },
  "run_conn_check": {
    "enable": 1,
    "mode": "check-connect-batch",
    "include_ff": true,
    "connect_trace": false,
    "checks": [
      {
        "id": "port_port",
        "a": "stress_top.probe_in",
        "b": "stress_top.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.probe_out"
      },
      {
        "id": "missing_hierarchy",
        "a": "stress_top.u_missing.probe_in",
        "b": "stress_top.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.u_spine.probe_out"
      }
    ],
    "output": "example_conn.tsv"
  },
  "run_io_trace": {
    "enable": 1,
    "mode": "inst-trace",
    "instance": "stress_top.u_spine",
    "direction": "both",
    "path_kind": "ff",
    "output": "example_trace.tsv"
  },
  "run_cone_trace": {
    "enable": 0,
    "mode": "fanout-cone",
    "fanout_cone": "stress_top.probe_in",
    "output": "example_cone.tsv"
  }
}