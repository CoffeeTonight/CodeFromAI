# EDA compile manifest — Test — authoritative campaign TB
# Order: incdirs → defines → vcpu → rtl → tb_top
# VCS:  vcs -sverilog -full64 -F filelists/eda/test/full_campaign/manifest.list -top tb_full_campaign
# xrun: xrun -64bit -sv -F filelists/eda/test/full_campaign/manifest.list -top tb_full_campaign
# Run from verif_cpu_verilog/ (package root)

-F filelists/eda/test/full_campaign/incdirs.list
-F filelists/eda/test/full_campaign/defines.list
-F filelists/eda/test/full_campaign/vcpu.list
-F filelists/eda/test/full_campaign/rtl.list
-F filelists/eda/test/full_campaign/tb_top.list
