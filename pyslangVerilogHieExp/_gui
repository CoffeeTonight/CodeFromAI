#!/bin/bash
#
# rtl_dql_gui launcher
# Usage: ./_gui
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GUI_SCRIPT="$SCRIPT_DIR/gui/rtl_dql_gui.py"

if [ ! -f "$GUI_SCRIPT" ]; then
    echo "Error: $GUI_SCRIPT not found"
    exit 1
fi

echo "Starting rtl_dql_gui..."
cd "$SCRIPT_DIR"
python3 "$GUI_SCRIPT" "$@"
