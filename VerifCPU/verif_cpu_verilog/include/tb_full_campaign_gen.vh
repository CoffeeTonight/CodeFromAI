`define CAMPAIGN_ICODE_AGENT_ROUNDS \
  begin : _gen_icode_rounds \
    integer _slot; \
    for (_slot = 0; _slot < `CAMPAIGN_MAX_ICODE_SLOTS; _slot = _slot + 1) begin \
      if (_slot > 0) begin \
