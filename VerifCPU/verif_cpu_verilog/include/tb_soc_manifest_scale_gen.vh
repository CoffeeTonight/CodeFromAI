  always @(posedge soc_clk) begin
    if (soc_rstn) begin
      if (!g_slv0.u_bus.u_cpu.sim_stop &&
          (g_slv0.u_bus.u_cpu.state == `CPU_STATE_RUNNING ||
           g_slv0.u_bus.u_cpu.state == `CPU_STATE_DUMMY))
        g_slv0.u_bus.u_cpu.cpu_step();
      if (!g_slv1.u_bus.u_cpu.sim_stop &&
          (g_slv1.u_bus.u_cpu.state == `CPU_STATE_RUNNING ||
           g_slv1.u_bus.u_cpu.state == `CPU_STATE_DUMMY))
        g_slv1.u_bus.u_cpu.cpu_step();
      if (!g_slv2.u_bus.u_cpu.sim_stop &&
          (g_slv2.u_bus.u_cpu.state == `CPU_STATE_RUNNING ||
           g_slv2.u_bus.u_cpu.state == `CPU_STATE_DUMMY))
        g_slv2.u_bus.u_cpu.cpu_step();
    end
  end

