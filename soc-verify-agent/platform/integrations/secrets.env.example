# Confluence & Jira credentials — copy to secrets.env and source before running.
# NEVER commit secrets.env (add to .gitignore).
#
#   cp platform/integrations/secrets.env.example secrets.env
#   ${EDITOR:-nano} secrets.env
#   set -a && source secrets.env && set +a

# --- Confluence Cloud (email + API token) ---
CONFLUENCE_USER_EMAIL=you@your-company.com
CONFLUENCE_API_TOKEN=

# --- Jira Cloud (email + API token) ---
JIRA_USER_EMAIL=you@your-company.com
JIRA_API_TOKEN=

# --- Server / Data Center (PAT only — uncomment if needed) ---
# CONFLUENCE_PAT=
# JIRA_PAT=

# --- OpenAI-compatible LLM (Chat Completions) ---
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=

# --- Legacy custom HTTP bridge (mode: http) ---
# COMPANY_LLM_TOKEN=

# --- Optional: git clone over SSH ---
# GIT_SSH_KEY_PATH=/home/user/.ssh/id_ed25519