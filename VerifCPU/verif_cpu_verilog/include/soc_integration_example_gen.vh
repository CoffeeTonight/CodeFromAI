    $display("========================================================================");

    wdata = 32'h0000CAFE;
    g_slv0.u_bus.u_bridge.bus_write(32'h40000000, wdata, 3'd4, resp);
    check("SFR APB3 write OK", resp == 2'd0);
    g_slv0.u_bus.u_bridge.bus_read(32'h40000000, 3'd4, rdata, resp);
    check("SFR APB3 read OK", resp == 2'd0);
    check("SFR APB3 data match", rdata == wdata);
    check("Agent SFR snoop", sl_txns[0] > 0);

    wdata = 32'h12345678;
    g_slv1.u_bus.u_bridge.bus_write(32'h80000000, wdata, 3'd4, resp);
    check("SRAM AHB_LITE write OK", resp == 2'd0);
    g_slv1.u_bus.u_bridge.bus_read(32'h80000000, 3'd4, rdata, resp);
