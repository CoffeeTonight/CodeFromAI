# EDA compile manifest — Test — integration TB (manifest slaves)
# Order: incdirs → defines → vcpu → rtl → tb_top
# VCS:  vcs -sverilog -full64 -F filelists/eda/test/soc_manifest/manifest.list -top tb_soc_manifest
# xrun: xrun -64bit -sv -F filelists/eda/test/soc_manifest/manifest.list -top tb_soc_manifest
# Run from verif_cpu_verilog/ (package root)

-F filelists/eda/test/soc_manifest/incdirs.list
-F filelists/eda/test/soc_manifest/defines.list
-F filelists/eda/test/soc_manifest/vcpu.list
-F filelists/eda/test/soc_manifest/rtl.list
-F filelists/eda/test/soc_manifest/tb_top.list
